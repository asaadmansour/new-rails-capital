<div id="<%= dom_id user %>">
  <div>
    <strong>Name:</strong>
    <%= user.name %>
  </div>

  <div>
    <strong>Dob:</strong>
    <%= user.dob %>
  </div>

  <div>
    <strong>Email:</strong>
    <%= user.email %>
  </div>

  <div>
    <strong>Phonenumber:</strong>
    <%= user.phoneNumber %>
  </div>

  <div>
    <strong>Address:</strong>
    <%= user.address %>
  </div>

</div>
